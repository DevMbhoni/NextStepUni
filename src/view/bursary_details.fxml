<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<BorderPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #f0f0f0;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BursaryDetailsController">
    <top>
        <VBox alignment="TOP_CENTER" BorderPane.alignment="CENTER">
            <children>
                <StackPane alignment="CENTER" prefHeight="70.0" style="-fx-background-color: #ff3131;">
                    <children>
                        <Label text="NextStepUni" textFill="WHITE">
                            <font>
                                <Font name="Britannic Bold" size="50.0" />
                            </font>
                        </Label>
                    </children>
                </StackPane>
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #d51e1e;">
                    <children>
                        <Button fx:id="homeBtn" onAction="#handleGoHome" prefHeight="45" prefWidth="45" style="-fx-background-color: transparent;">
                            <graphic>
                                <ImageView fitHeight="30" fitWidth="30" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/icons/home.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <HBox.margin>
                                <Insets left="15.0" />
                            </HBox.margin>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <StackPane>
                            <children>
                                <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLoginRegister" style="-fx-background-color: white; -fx-background-radius: 5;" text="Login/Register">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Button>

                                <MenuButton fx:id="profileButton" contentDisplay="GRAPHIC_ONLY" managed="false" mnemonicParsing="false" style="-fx-background-color: transparent;" visible="false">
                                    <items>
                                        <MenuItem mnemonicParsing="false" onAction="#handleViewProfile" text="View Profile" />
                                        <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
                                    </items>
                                    <graphic>
                                        <ImageView fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@/images/icons/profile_icon.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </MenuButton>
                            </children>
                            <HBox.margin>
                                <Insets right="20.0" />
                            </HBox.margin>
                        </StackPane>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <left>
        <VBox alignment="TOP_LEFT" BorderPane.alignment="CENTER">
            <children>
                <Button onAction="#handleBackClick"
                        style="-fx-background-color: #d51e1e; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Back">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
            <BorderPane.margin>
                <Insets left="20.0" top="20.0" />
            </BorderPane.margin>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #f0f0f0;" BorderPane.alignment="CENTER">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="50.0" top="20.0" />
                    </padding>
                    <children>
                        <Label fx:id="bursaryNameLabel" text="Bursary Name Goes Here">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                        <VBox alignment="TOP_CENTER" maxWidth="800.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Application Deadline:" />
                                        <Label fx:id="deadlineLabel" text="YYYY-MM-DD" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Website:" />
                                        <Hyperlink fx:id="websiteLink" onAction="#handleWebsiteClick" text="https://website.com" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox maxWidth="800.0" spacing="5.0">
                            <children>
                                <Label text="Description">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="descriptionArea" editable="false" prefHeight="150.0" style="-fx-background-color: white; -fx-border-color: #cccccc;" wrapText="true" />
                            </children>
                        </VBox>
                        <VBox maxWidth="800.0" spacing="5.0">
                            <children>
                                <Label text="Required Qualifications">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <ListView fx:id="qualificationsListView" prefHeight="150.0" style="-fx-border-color: #cccccc;" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="80.0" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets right="50.0" />
            </padding>
            <children>
                <Button fx:id="applyButton" onAction="#handleApplyNow" style="-fx-background-color: #d51e1e; -fx-text-fill: white; -fx-font-weight: bold;" text="Apply Now" prefWidth="120.0" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
